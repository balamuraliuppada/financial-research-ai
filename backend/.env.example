# ──────────────────────────────────────────────────────────────────────────────
# Financial Research AI — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI / LLM ──────────────────────────────────────────────────────────────────

# Required — Gemini API key for the AI research assistant
# Get a free key at: https://aistudio.google.com
GOOGLE_API_KEY=your-gemini-api-key-here

# ── LangSmith Tracing (optional but recommended for production) ───────────────
# Set LANGCHAIN_TRACING_V2=true to activate LangSmith tracing.
# Traces are viewable at https://smith.langchain.com
# Get a free API key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=financial-research-ai

# ── Market Data APIs ──────────────────────────────────────────────────────────

# Optional — fallback stock data source (5 req/min on free tier)
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# Required for news sentiment — free tier: 100 req/day
# Get a free key at: https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key-here

# ── Caching ───────────────────────────────────────────────────────────────────

# Optional — Redis URL for response caching.
# Upstash free tier: https://console.upstash.com (10,000 req/day)
# Leave empty to disable caching (fallback to no-cache mode).
REDIS_URL=rediss://default:your-password@your-host.upstash.io:6379

# ── Database ──────────────────────────────────────────────────────────────────

# Optional — production PostgreSQL connection string.
# Leave empty to use SQLite (local development default).
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Security ──────────────────────────────────────────────────────────────────

# Optional — shared API key for all backend endpoints.
# Leave empty to disable authentication (local development only).
# Set a strong random value in production to protect the Render deployment.
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────

# Required in production — the URL of your deployed frontend.
# Example: https://your-frontend.onrender.com
FRONTEND_ORIGIN=http://localhost:3000
